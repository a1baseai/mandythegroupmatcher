# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000

# AI Service API Keys
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# Mandy (Group Matchmaker) Email/Chat + Admin Dashboard
MANDY_AGENT_ID=your_mandy_agent_id_here
MANDY_API_KEY=your_a1zap_api_key_here
MANDY_AGENT_SLUG=mandythematchmaker

# Optional: protect /admin + sensitive /api/* routes (defaults shown)
MANDY_ADMIN_USER=admin
MANDY_ADMIN_PASSWORD=a1zapped!

# Recommended in production: protect inbound integration endpoints
# If set, /api/groups/receive requires:
# - Authorization: Bearer <token> OR X-Ingest-Token: <token>
MANDY_INGEST_TOKEN=your_random_long_token_here
#
# If set, /webhook/mandy requires:
# - X-Webhook-Secret: <secret>
MANDY_WEBHOOK_SECRET=your_webhook_secret_here

# A1Zap Agent Configurations
# Claude Docubot Agent
A1ZAP_API_KEY=your_a1zap_api_key_here
A1ZAP_AGENT_ID=your_agent_id_here
